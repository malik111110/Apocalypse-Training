# Apocalypse Platform — Environment Variables
# Copy this file to .env and fill in all secret values before running:
#   podman-compose up --build --wait
#
# Security notes:
# - Never commit .env files to version control
# - Use Podman secrets or a vault in production
# - Rotate JWT_SECRET after initial deployment

# ─── General ───
APP_NAME=Apocalypse Core
APP_ENV=production
APP_LOG_LEVEL=INFO
APP_HTTP_ADDR=:8080
APP_API_PREFIX=/api
APP_MAX_TOOL_CALLS=3
APP_ENABLE_MOCK_LLM=false
APP_DEFAULT_ORG_ID=org-default

# ─── Authentication ───
APP_AUTH_REQUIRED=true
APP_JWT_SECRET=replace-with-a-256-bit-secret-minimum-32-chars-long
APP_JWT_EXPIRY_SECONDS=3600

# ─── CORS ───
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ─── Rate Limiting ───
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_FAIL_OPEN=false

# ─── Request Limits ───
MAX_REQUEST_SIZE_BYTES=1048576

# ─── LLM Provider ───
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# ─── Session Store ───
REDIS_URL=redis://apocalypse-redis:6379/0
APP_SESSION_STORE_BACKEND=redis
APP_SESSION_TTL_SECONDS=86400
APP_SESSION_MAX_MESSAGES=50

# ─── Database ───
POSTGRES_USER=apocalypse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=apocalypse
POSTGRES_DSN=postgresql://apocalypse:changeme@apocalypse-postgres:5432/apocalypse
APP_AUDIT_BACKEND=postgres
APP_IDENTITY_BACKEND=postgres

# ─── OpenSandbox (optional) ───
OPENSANDBOX_BASE_URL=
OPENSANDBOX_API_KEY=
OPENSANDBOX_EXECD_URL=
OPENSANDBOX_EXECD_TOKEN=
OPENSANDBOX_TIMEOUT_SECONDS=20

# ─── Frontend Build ───
VITE_API_BASE_URL=/api
